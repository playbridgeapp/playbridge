<?xml version="1.0" encoding="utf-8"?>
<!--
  PlayerView backed by a SurfaceView (the default). SurfaceView enables the Android
  system compositor to pass the raw video buffer directly to the display hardware,
  allowing correct, native hardware-accelerated HDR tone-mapping and full brightness.
-->
<androidx.media3.ui.PlayerView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/player_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    app:surface_type="surface_view"
    app:use_controller="false"
    app:resize_mode="fit" />
