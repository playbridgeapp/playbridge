{
    "manifest_version": 2,
    "name": "PlayBridge Bridge",
    "version": "1.2",
    "description": "Native JS evaluation bridge for PlayBridge TV",
    "browser_specific_settings": {
        "gecko": {
            "id": "pb-bridge@playbridge.com"
        }
    },
    "permissions": [
        "nativeMessaging",
        "activeTab",
        "tabs",
        "<all_urls>"
    ],
    "background": {
        "scripts": ["background.js"]
    },
    "content_scripts": [{
        "matches": ["<all_urls>"],
        "js": ["content.js"],
        "run_at": "document_start",
        "all_frames": true
    }]
}
