<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <SurfaceView
        android:id="@+id/surface_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_centerInParent="true" />

    <!-- Buffering Spinner (centered) -->
    <ProgressBar
        android:id="@+id/buffering_spinner"
        style="?android:attr/progressBarStyle"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_centerInParent="true"
        android:indeterminate="true"
        android:indeterminateDrawable="@drawable/custom_spinner"
        android:visibility="gone" />

    <!-- Controls Overlay (gradient background) -->
    <RelativeLayout
        android:id="@+id/controls_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/gradient_player_overlay"
        android:visibility="gone">

        <!-- ===== TOP BAR ===== -->
        <LinearLayout
            android:id="@+id/top_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:orientation="vertical"
            android:paddingStart="40dp"
            android:paddingEnd="40dp"
            android:paddingTop="32dp">

            <TextView
                android:id="@+id/tv_season_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#B0B0B0"
                android:textSize="14sp"
                android:fontFamily="sans-serif"
                android:maxLines="1"
                android:visibility="gone"
                android:shadowColor="@android:color/black"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="3" />

            <TextView
                android:id="@+id/title_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="4dp"
                android:textColor="@android:color/white"
                android:textSize="22sp"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:ellipsize="end"
                android:shadowColor="@android:color/black"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="3" />
        </LinearLayout>


        <!-- ===== BOTTOM SECTION ===== -->
        <LinearLayout
            android:id="@+id/bottom_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:orientation="vertical"
            android:paddingStart="40dp"
            android:paddingEnd="40dp"
            android:paddingBottom="24dp">

            <!-- Stream info (resolution, codec, etc.) -->
            <TextView
                android:id="@+id/tv_stream_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#B0B0B0"
                android:textSize="12sp"
                android:fontFamily="sans-serif"
                android:maxLines="1"
                android:ellipsize="end"
                android:visibility="gone" />

            <!-- Seekbar Row & Time Row -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:paddingTop="12dp"
                android:paddingBottom="12dp">

                <TextView
                    android:id="@+id/tv_elapsed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_alignParentStart="true"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:text="00:00" />

                <com.playbridge.player.player.BufferSeekBar
                    android:id="@+id/player_seekbar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/tv_elapsed"
                    android:layout_toStartOf="@+id/tv_remaining"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:max="1000"
                    android:progressDrawable="@drawable/selector_custom_seekbar"
                    android:thumb="@android:color/transparent"
                    android:splitTrack="false"
                    android:background="@android:color/transparent"
                    android:focusable="false"
                    android:clickable="false"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp" />

                <TextView
                    android:id="@+id/tv_remaining"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_alignParentEnd="true"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:text="00:00" />
            </RelativeLayout>

            <!-- Controls Row: play/pause on the left, tracks/settings on the right -->
            <LinearLayout
                android:id="@+id/controls_panel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageButton
                    android:id="@+id/btn_prev"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/selector_player_button"
                    android:src="@drawable/ic_skip_previous"
                    android:scaleType="fitCenter"
                    android:padding="6dp"
                    android:contentDescription="Previous Episode"
                    android:focusable="true"
                    android:visibility="gone"
                    android:nextFocusUp="@id/player_seekbar"
                    android:nextFocusLeft="@id/btn_prev"
                    android:nextFocusRight="@id/btn_play_pause" />

                <ImageButton
                    android:id="@+id/btn_play_pause"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/selector_player_button"
                    android:src="@drawable/ic_play"
                    android:scaleType="fitCenter"
                    android:padding="6dp"
                    android:contentDescription="Play/Pause"
                    android:focusable="true"
                    android:focusedByDefault="true"
                    android:nextFocusUp="@id/player_seekbar"
                    android:nextFocusLeft="@id/btn_prev"
                    android:nextFocusRight="@id/btn_next" />

                <ImageButton
                    android:id="@+id/btn_next"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/selector_player_button"
                    android:src="@drawable/ic_skip_next"
                    android:scaleType="fitCenter"
                    android:padding="6dp"
                    android:contentDescription="Next Episode"
                    android:focusable="true"
                    android:visibility="gone"
                    android:nextFocusUp="@id/player_seekbar"
                    android:nextFocusLeft="@id/btn_play_pause" />

                <!-- Weighted spacer pushes right-side buttons to the right -->
                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <ImageButton
                    android:id="@+id/btn_playlist"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/selector_player_button"
                    android:src="@drawable/ic_list"
                    android:scaleType="fitCenter"
                    android:padding="6dp"
                    android:contentDescription="Playlist"
                    android:focusable="true"
                    android:visibility="gone"
                    android:nextFocusUp="@id/player_seekbar"
                    android:nextFocusRight="@id/btn_filter" />

                <ImageButton
                    android:id="@+id/btn_filter"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/selector_player_button"
                    android:src="@drawable/ic_filter"
                    android:scaleType="fitCenter"
                    android:padding="6dp"
                    android:contentDescription="Video Filters"
                    android:focusable="true"
                    android:nextFocusUp="@id/player_seekbar"
                    android:nextFocusLeft="@id/btn_playlist"
                    android:nextFocusRight="@id/btn_tracks" />

                <ImageButton
                    android:id="@+id/btn_tracks"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/selector_player_button"
                    android:src="@drawable/ic_settings"
                    android:scaleType="fitCenter"
                    android:padding="6dp"
                    android:contentDescription="Tracks / Settings"
                    android:focusable="true"
                    android:nextFocusUp="@id/player_seekbar"
                    android:nextFocusRight="@id/btn_tracks"
                    android:nextFocusLeft="@id/btn_filter" />
            </LinearLayout>
        </LinearLayout>
    </RelativeLayout>
</RelativeLayout>
