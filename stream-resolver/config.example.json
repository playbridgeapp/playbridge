{
  "port": 7001,
  "base_url": "http://localhost:7001",
  "addons": [
    {
      "url": "https://your-aiostreams-host/stremio/YOUR-UUID/YOUR-ENCRYPTED-PASSWORD",
      "name": "AIOStreams",
      "priority": 0,
      "timeout_ms": 8000
    },
    {
      "url": "https://hdhub.example.com",
      "name": "HDHub",
      "priority": 1,
      "timeout_ms": 5000
    }
  ],
  "meta_addons": [
    {
      "url": "https://v3-cinemeta.strem.io",
      "name": "Cinemeta",
      "timeout_ms": 5000
    }
  ],
  "probing": {
    "enabled": true,
    "max_attempts": 5,
    "timeout_ms": 15000
  },
  "cache": {
    "stream_list_ttl_seconds": 300,
    "play_result_ttl_seconds": 3600,
    "meta_ttl_seconds": 86400
  },
  "defaults": {
    "quality": "",
    "source_type": [],
    "source": "",
    "audio_lang": "",
    "min_size": 0,
    "max_size": 0,
    "min_bitrate": 0,
    "max_bitrate": 0
  }
}
